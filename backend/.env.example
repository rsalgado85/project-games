APP_NAME=GameVault
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.vercel.app
APP_TIMEZONE=UTC

LOG_CHANNEL=stderr
LOG_LEVEL=error

# Database (not required for API-only backend)
DB_CONNECTION=sqlite
DB_DATABASE=/tmp/database.sqlite

CACHE_STORE=file
CACHE_PREFIX=gamevault_

SESSION_DRIVER=file
SESSION_LIFETIME=120

# RAWG API — NEVER expose this to the frontend!
RAWG_API_KEY=your_rawg_api_key_here
RAWG_BASE_URL=https://api.rawg.io/api

# Rate Limiting
RATE_LIMIT_GAMES=60
RATE_LIMIT_CONTACT=5

# Mail (for contact form)
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@gamevault.app"
MAIL_FROM_NAME="GameVault"
CONTACT_RECIPIENT_EMAIL=hello@example.com

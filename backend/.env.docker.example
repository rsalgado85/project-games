APP_NAME=GameVault
APP_ENV=production
APP_DEBUG=false
APP_URL=http://localhost:19090
APP_PORT=9000
APP_TIMEZONE=UTC

LOG_CHANNEL=stderr
LOG_LEVEL=error

DB_CONNECTION=sqlite
DB_DATABASE=/var/www/backend/database/database.sqlite

CACHE_STORE=file
CACHE_PREFIX=gamevault_

SESSION_DRIVER=file
SESSION_LIFETIME=120

# Required
RAWG_API_KEY=replace_with_your_rawg_api_key
RAWG_BASE_URL=https://api.rawg.io/api

# Optional mail setup
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=noreply@gamevault.app
MAIL_FROM_NAME=GameVault
CONTACT_RECIPIENT_EMAIL=hello@example.com
